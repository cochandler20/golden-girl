# ============================================================
# .htaccess — Apache Configuration for Golden Girl (XAMPP)
#
# REQUIREMENTS (in C:\xampp\apache\conf\httpd.conf):
#   1. LoadModule rewrite_module modules/mod_rewrite.so  — uncommented
#   2. LoadModule headers_module  modules/mod_headers.so — uncommented
#   3. AllowOverride All  — set on the htdocs <Directory> block
#
# After any change here or in httpd.conf, restart Apache via
# the XAMPP Control Panel for changes to take effect.
# ============================================================


# ── Directory Listing ─────────────────────────────────────────
# Prevent Apache from showing a file/folder listing when no
# index file exists. Without this, visitors could browse your
# entire project structure in the browser.
Options -Indexes


# ── Default Index File ────────────────────────────────────────
# Tell Apache which file to serve when a directory is requested.
# Visiting /golden-girl/ will automatically serve index.php.
DirectoryIndex index.php


# ── Block Direct Access to Sensitive Files ────────────────────
# Deny direct browser access to database.php and auth.php.
# These files contain credentials and session logic — they
# should only ever be included by other PHP files, never
# requested directly via a URL.
#
# Note: <FilesMatch> matches by filename only, not full path.
# The regex anchors (^ and $) ensure we match the exact names.
<FilesMatch "^(database|auth)\.php$">
    Require all denied
</FilesMatch>


# ── URL Rewriting (Clean URLs) ────────────────────────────────
# Requires mod_rewrite to be loaded in httpd.conf.
# This block lets visitors use /login instead of /login.php,
# /blog instead of /blog.php, etc.
<IfModule mod_rewrite.c>

    # Turn on the rewrite engine for this directory
    RewriteEngine On

    # Set the base path so rewrites work correctly inside a
    # subdirectory. This must match the folder name under htdocs.
    # If you later deploy to the server root, change this to /
    RewriteBase /golden-girl/

    # -- Block direct access to sensitive directories ----------
    # If the URL starts with "config/" or "includes/", return
    # a 403 Forbidden response immediately.
    # Flags: [F] = Forbidden (403), [L] = stop processing rules
    RewriteRule ^config/   - [F,L]
    RewriteRule ^includes/ - [F,L]

    # -- Redirect /index and /index.php to the root URL --------
    # Visiting /golden-girl/index or /golden-girl/index.php
    # will permanently redirect to /golden-girl/ so there is
    # only one canonical URL for the homepage.
    # [R=301] = permanent redirect (browsers and search engines
    #           will update their records to the new URL)
    # [L]     = stop processing any further rules after this one
    RewriteRule ^index(\.php)?$ /golden-girl/ [R=301,L]

    # -- Skip rewriting for real files (CSS, JS, images, etc.) -
    # If the requested path points to an actual file on disk,
    # serve it directly without any rewriting.
    RewriteCond %{REQUEST_FILENAME} !-f

    # -- Skip rewriting for real directories ------------------
    # If the requested path is an actual folder, serve it directly.
    RewriteCond %{REQUEST_FILENAME} !-d

    # -- Rewrite extensionless URLs to .php -------------------
    # If neither condition above matched (no real file/folder),
    # append .php to the request and serve that file instead.
    #
    # Example: /login  → login.php
    #          /blog   → blog.php
    #          /about  → about.php
    #
    # [^.]+ matches one or more characters that are NOT a dot,
    # so URLs that already have an extension are left alone.
    # Flags: [NC] = case-insensitive, [L] = stop here
    RewriteRule ^([^.]+)$ $1.php [NC,L]

</IfModule>


# ── HTTP Security Headers ─────────────────────────────────────
# Requires mod_headers to be loaded in httpd.conf.
# These headers tell browsers how to handle your site's content
# and protect against several common attack categories.
<IfModule mod_headers.c>

    # Prevent browsers from guessing (sniffing) the content type.
    # Without this, a browser might execute a text file as JavaScript.
    Header set X-Content-Type-Options "nosniff"

    # Allow the page to be embedded in iframes only from the same
    # origin. Blocks clickjacking attacks from external sites.
    Header set X-Frame-Options "SAMEORIGIN"

    # Tell browsers not to send the full URL in the Referer header
    # when navigating from HTTPS to HTTP, protecting user privacy.
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Disable browser features this site does not use.
    # Prevents malicious scripts from accessing camera, mic, or GPS.
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Remove the X-Powered-By header that Apache/PHP adds by default.
    # This hides the PHP version number from potential attackers.
    Header unset X-Powered-By

</IfModule>


# ── Protect This File ─────────────────────────────────────────
# Deny any direct browser request for the .htaccess file itself.
# Visitors should never be able to read your server configuration.
<Files ".htaccess">
    Require all denied
</Files>


# ── Custom Error Pages (uncomment when files are created) ──────
# ErrorDocument 403 /golden-girl/errors/403.php
# ErrorDocument 404 /golden-girl/errors/404.php
# ErrorDocument 500 /golden-girl/errors/500.php
